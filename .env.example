# SignSpeak — Variables de entorno
# Copia este archivo como .env y ajusta los valores

ENVIRONMENT=development
LOG_LEVEL=INFO

# ── API Gateway ──────────────────────────────────────────────────────────────
PORT=8080
VISION_SERVICE_URL=http://localhost:8080
TRANSLATION_SERVICE_URL=http://localhost:8081
HTTP_TIMEOUT=30.0
HTTP_CONNECT_TIMEOUT=5.0
CORS_ORIGINS=*

# ── Vision Service ───────────────────────────────────────────────────────────
VISION_PORT=8080
MIN_WINDOW_CONFIDENCE=60.0
HIGH_CONFIDENCE_THRESHOLD=80
MOVEMENT_THRESHOLD=0.15

# Hugging Face Hub — repo de modelos ML
# Repo público: no necesita HF_TOKEN
HF_MODEL_REPO=alanctinaDev/signspeak-models
HF_TOKEN=

# ── GCP Cloud Run (CI/CD) ────────────────────────────────────────────────────
# Configura estos como Repository Variables en GitHub (no secrets)
# GCP_PROJECT_ID=signspeak-prod
# GCP_REGION=us-central1
# HF_MODEL_REPO=alanctinaDev/signspeak-models

# ── GCP Secrets en GitHub Actions ────────────────────────────────────────────
# Configura estos como Repository Secrets en GitHub:
# GCP_SA_KEY=<JSON de tu Service Account>
# HF_TOKEN=<token HF si el repo es privado>
