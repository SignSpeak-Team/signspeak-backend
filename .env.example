# SignSpeak — Plantilla de variables de entorno
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env

# Entorno de ejecución: development | production
ENVIRONMENT=development

# URL del Vision Service (inferencia ML)
VISION_SERVICE_URL=http://localhost:8001

# Puerto del API Gateway
PORT=8000

# CORS — En producción reemplaza con tu dominio real
# Ejemplo: https://tu-app.vercel.app
CORS_ORIGINS=*
